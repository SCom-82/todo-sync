# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/todo_sync

# Microsoft Entra App Registration
MS_CLIENT_ID=your-client-id-from-entra
MS_TENANT_ID=consumers

# Sync interval in seconds (default: 300 = 5 min)
SYNC_INTERVAL_SECONDS=300

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API key for authentication (leave empty to disable auth — for local dev only)
API_KEY=
